{
  "name": "royal-game-of-ur",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:backend": "rm -rf backend/modules/build && npx --yes esbuild backend/modules/index.ts --bundle --platform=neutral --format=esm --target=es2017 --outfile=backend/modules/build/backend/modules/index.js",
    "backend:up": "npm run build:backend && docker compose --env-file backend/.env -f backend/docker-compose.yml up -d",
    "backend:dev": "npm run build:backend && docker compose --env-file backend/.env -f backend/docker-compose.yml up",
    "backend:prod:up": "docker compose --env-file backend/deploy/env.production -f backend/deploy/docker-compose.prod.yml up -d",
    "backend:prod:ps": "docker compose --env-file backend/deploy/env.production -f backend/deploy/docker-compose.prod.yml ps",
    "backend:prod:health": "./scripts/backend-prod-healthcheck.sh",
    "backend:prod:redeploy": "./scripts/backend-prod-redeploy.sh",
    "backend:prod:logs": "docker compose --env-file backend/deploy/env.production -f backend/deploy/docker-compose.prod.yml logs -f",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@heroiclabs/nakama-js": "^2.8.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.31",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
