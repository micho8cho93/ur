# Public DNS name for Nakama, without protocol.
NAKAMA_DOMAIN=nakama.example.com

# Keep these secret in production.
POSTGRES_PASSWORD=replace-this-postgres-password
NAKAMA_SOCKET_SERVER_KEY=replace-this-server-key
NAKAMA_HTTP_KEY=replace-this-http-key
NAKAMA_CONSOLE_USERNAME=replace-this-console-username
NAKAMA_CONSOLE_PASSWORD=replace-this-console-password
NAKAMA_CONSOLE_SIGNING_KEY=replace-this-console-signing-key
NAKAMA_SESSION_ENCRYPTION_KEY=replace-this-session-encryption-key
NAKAMA_SESSION_REFRESH_ENCRYPTION_KEY=replace-this-refresh-session-encryption-key
