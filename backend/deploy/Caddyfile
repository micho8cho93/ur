{$NAKAMA_DOMAIN} {
  route {
    @public_nakama_preflight {
      method OPTIONS
      path /v2/* /ws /ws/* /healthcheck
      header Origin https://urgame.live
    }

    handle @public_nakama_preflight {
      header Access-Control-Allow-Origin https://urgame.live
      header Access-Control-Allow-Credentials true
      header Access-Control-Allow-Headers "Authorization, Content-Type, X-Requested-With"
      header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
      header Vary Origin
      respond "" 204
    }

    @public_nakama path /v2/* /ws /ws/* /healthcheck
    handle @public_nakama {
      # Let Nakama supply CORS on actual responses. Adding origin headers here
      # duplicates Nakama's own `Access-Control-Allow-Origin: *` header and
      # breaks browser auth requests with a multiple-values CORS error.
      reverse_proxy nakama:7350
    }

    encode zstd gzip
  }
}

admin-nakama.urgame.live {
  reverse_proxy nakama:7351
}

internals.urgame.live {
  log {
    output stdout
    format console
  }

  route {
    @internals_nakama_preflight {
      method OPTIONS
      path /v2/* /ws /ws/* /healthcheck
      header Origin https://internals.urgame.live
    }

    handle @internals_nakama_preflight {
      header Access-Control-Allow-Origin https://internals.urgame.live
      header Access-Control-Allow-Credentials true
      header Access-Control-Allow-Headers "Authorization, Content-Type, X-Requested-With"
      header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
      header Vary Origin
      respond "" 204
    }

    @internals_nakama path /v2/* /ws /ws/* /healthcheck
    handle @internals_nakama {
      # Keep preflight handling here, but do not add CORS headers to proxied
      # responses or they will conflict with Nakama's own headers.
      reverse_proxy nakama:7350
    }

    encode zstd gzip
    root * /var/www/internals
    try_files {path} /index.html
    file_server
  }
}
